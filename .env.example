# App config
APP_BASE_URL=http://localhost:3000
SESSION_SECRET=change-me-to-a-long-random-string

# Seed admin (created on first `npm run seed`)
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=changeme

# iOS / Android bindings for Universal Links and App Links
IOS_APP_ID_PREFIX=ABCDE12345
IOS_BUNDLE_ID=az.nar.app
ANDROID_PACKAGE_NAME=az.nar.app
ANDROID_SHA256_FINGERPRINTS=AA:BB:CC:DD:EE:FF:00:11:22:33:44:55:66:77:88:99:AA:BB:CC:DD:EE:FF:00:11:22:33:44:55:66:77:88:99

# App Store / Play Store fallbacks if app isn't installed
IOS_STORE_URL=https://apps.apple.com/app/id0000000000
ANDROID_STORE_PACKAGE=az.nar.app

# Optional Bitly shortening
BITLY_TOKEN=
BITLY_DOMAIN=bit.ly
